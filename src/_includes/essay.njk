---
layout: base.njk
ogType: article
---

{% block head %}
<style>
  .article-meta { display:flex;gap:24px;padding:var(--section-v) var(--pad) 0;align-items:center; }
  .article-tag { font-family:'Lato',sans-serif;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-muted); }
  .article-date { font-family:'Lato',sans-serif;font-size:10px;letter-spacing:0.08em;color:var(--ink-faint); }
  .article-header { display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;padding:28px var(--pad) var(--section-v);border-bottom:0.5px solid var(--rule); }
  .article-title { font-size:52px;font-weight:400;line-height:1.1;letter-spacing:-0.035em; }
  .article-title em { font-style:italic;color:var(--red); }
  .article-standfirst { font-family:'Lato',sans-serif;font-size:21px;font-weight:300;color:var(--ink-mid);line-height:1.65;border-left:2px solid var(--red);padding-left:20px; }
  .article-hero-img { aspect-ratio:16/7;border-bottom:0.5px solid var(--rule);background:var(--cream-mid); }
  .article-body { max-width:680px;margin:0 auto;padding:var(--section-v) var(--pad); }
  .article-body p { font-family:'Lato',sans-serif;font-size:17px;font-weight:300;color:var(--ink-mid);line-height:1.85; }
  .article-body p+p { margin-top:24px; }
  .article-body ol { margin:32px 0 32px 24px; }
  .article-body ol li { font-family:'Lato',sans-serif;font-size:17px;font-weight:300;color:var(--ink-mid);line-height:1.85;margin-bottom:16px; }
  .pull-quote { margin:48px 0;padding:0 0 0 24px;border-left:2px solid var(--red); }
  .pull-quote p { font-family:Georgia,serif;font-size:24px;font-weight:400;font-style:italic;color:var(--ink);line-height:1.45;letter-spacing:-0.015em; }
  .pull-quote p+p { margin-top:0 !important; }
  .body-break { display:block;width:56px;height:1px;background:var(--red);border:none;margin:48px 0; }
  .article-back { padding:0 var(--pad) var(--section-v);max-width:680px;margin:0 auto; }
  .article-back a { font-family:'Lato',sans-serif;font-size:13px;color:var(--red);text-decoration:none; }
  @media (max-width:768px) {
    .article-header { grid-template-columns:1fr;gap:32px; }
    .article-title { font-size:36px; }
  }
</style>
{% endblock %}

{% block content %}
  <div class="article-meta">
    <span class="article-tag">{{ tag }}</span>
    <span class="article-date">{{ page.date | date("YYYY") }}</span>
    <span class="article-date">{{ content | readingTime }}</span>
  </div>

  <div class="article-header">
    <h1 class="article-title">{{ titleHtml | safe }}</h1>
    <p class="article-standfirst">{{ standfirst }}</p>
  </div>

  {% if heroImage %}
  <div class="article-hero-img img-wrap">
    <img src="/images/{{ heroImage }}" alt="{{ title }}">
  </div>
  {% endif %}

  <div class="article-body">
    {{ content | safe }}
  </div>

  <div class="article-back"><a href="/thinking/">← Back to Bigalisms</a></div>
{% endblock %}
