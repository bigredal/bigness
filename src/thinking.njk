---
layout: base.njk
title: "Bigalisms"
description: "Essays and musings on leadership, creativity and change from Al Reid. Musings and amusings from coach, cyclist and worker bee."
ogImage: IMG_6789.jpg
---

{% block head %}
<style>
  .articles-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    padding: var(--section-v) var(--pad);
    gap: 32px;
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .article-card { display:flex;flex-direction:column;text-decoration:none;color:inherit; }
  .card-img-wrap { position:relative;overflow:hidden; }
  .card-img-wrap img { width:100%;height:100%;object-fit:cover;display:block; }
  .card-img-wrap::after { content:'';position:absolute;inset:0;background:rgba(184,64,46,0.20);transition:opacity 0.35s ease;z-index:1; }
  .article-card:hover .card-img-wrap::after { opacity:0; }
  .card-title-overlay { position:absolute;bottom:0;left:0;right:0;padding:20px 24px;background:linear-gradient(to bottom,transparent,rgba(26,25,22,0.78));z-index:2; }
  .card-title { font-family:Georgia,serif;font-size:18px;font-weight:400;line-height:1.3;color:#fff;letter-spacing:-0.01em; }
  .card-read-time { font-family:'Lato',sans-serif;font-size:11px;color:rgba(255,255,255,0.7);margin-top:6px; }
  .card-body { padding:16px 0 0; }
  .card-tag { font-family:'Lato',sans-serif;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--red);margin-bottom:8px; }
  .card-desc { font-family:'Lato',sans-serif;font-size:14px;font-weight:300;color:var(--ink-mid);line-height:1.6; }

  .col-span-1 { grid-column:span 1; }
  .col-span-2 { grid-column:span 2; }
  .col-span-3 { grid-column:span 3; }

  .col-span-2 .card-img-wrap,
  .col-span-1 .card-img-wrap { height:clamp(240px,28vw,400px); }
  .col-span-3 .card-img-wrap { aspect-ratio:21/8; }
  .col-span-3 .card-body { display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start; }

  @media (max-width:900px) {
    .articles-grid { grid-template-columns:1fr 1fr;padding:var(--section-v) var(--pad); }
    .col-span-2,.col-span-3 { grid-column:span 2; }
    .col-span-3 .card-body { grid-template-columns:1fr;gap:0; }
  }
  @media (max-width:600px) {
    .articles-grid { grid-template-columns:1fr; }
    .col-span-2,.col-span-3 { grid-column:span 1; }
    .col-span-2 .card-img-wrap,.col-span-3 .card-img-wrap { aspect-ratio:16/9; }
  }
</style>
{% endblock %}

{% block content %}
  <header class="page-header">
    <div class="page-header-left">
      <h1>Big<em>alisms.</em></h1>
    </div>
    <div class="page-header-right">
      <div class="page-header-sub">Musings and amusings from coach, cyclist and worker bee.</div>
    </div>
  </header>

  <div class="articles-grid">
    {% set essayList = collections.essays | reverse %}
    {% for essay in essayList %}
      {% if loop.index == 1 %}
      <a href="{{ essay.url }}" class="article-card col-span-2">
        <div class="card-img-wrap">
          {% if essay.data.heroImage %}
          <img src="/images/{{ essay.data.heroImage }}" alt="{{ essay.data.title }}">
          {% endif %}
          <div class="card-title-overlay">
            <div class="card-title">{{ essay.data.title }}</div>
            <div class="card-read-time">{{ essay.templateContent | readingTime }}</div>
          </div>
        </div>
        <div class="card-body">
          <div class="card-tag">{{ essay.data.tag }}</div>
          <div class="card-desc">{{ essay.data.standfirst }}</div>
        </div>
      </a>
      {% elif loop.index == 2 %}
      <a href="{{ essay.url }}" class="article-card col-span-1">
        <div class="card-img-wrap">
          {% if essay.data.heroImage %}
          <img src="/images/{{ essay.data.heroImage }}" alt="{{ essay.data.title }}">
          {% endif %}
          <div class="card-title-overlay">
            <div class="card-title">{{ essay.data.title }}</div>
            <div class="card-read-time">{{ essay.templateContent | readingTime }}</div>
          </div>
        </div>
        <div class="card-body">
          <div class="card-tag">{{ essay.data.tag }}</div>
          <div class="card-desc">{{ essay.data.standfirst }}</div>
        </div>
      </a>
      {% else %}
      <a href="{{ essay.url }}" class="article-card col-span-3">
        <div class="card-img-wrap">
          {% if essay.data.heroImage %}
          <img src="/images/{{ essay.data.heroImage }}" alt="{{ essay.data.title }}">
          {% endif %}
          <div class="card-title-overlay">
            <div class="card-title">{{ essay.data.title }}</div>
            <div class="card-read-time">{{ essay.templateContent | readingTime }}</div>
          </div>
        </div>
        <div class="card-body">
          <div class="card-tag">{{ essay.data.tag }}</div>
          <div class="card-desc">{{ essay.data.standfirst }}</div>
        </div>
      </a>
      {% endif %}
    {% endfor %}
  </div>
{% endblock %}
